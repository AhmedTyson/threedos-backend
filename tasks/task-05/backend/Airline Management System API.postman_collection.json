          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employees?id=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employees"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            },
            "description": "Removes an employee. Fails if they are part of an active crew."
