            "description": "Retrieves all airlines registered in the system."
          },
          "response": []
        },
        {
          "name": "Get Airline by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/airlines?id=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "airlines"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Airline ID"
                }
              ]
