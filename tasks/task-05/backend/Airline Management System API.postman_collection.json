              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"origin\": \"Cairo (CAI)\",\n    \"destination\": \"Dubai (DXB)\",\n    \"distance\": 2407,\n    \"classification\": \"International\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/routes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "routes"
              ]
            },
            "description": "Defines a new flight route. Returns the full created record."
          },
          "response": []
        },
        {
          "name": "Schedule Flight (Assign Route)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"aircraft_id\": 1,\n    \"route_id\": 1,\n    \"departure\": \"2026-06-15 08:00:00\",\n    \"arrival\": \"2026-06-15 12:30:00\",\n    \"passengers\": 280,\n    \"ticket_price\": 450\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/assign-route",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "assign-route"
