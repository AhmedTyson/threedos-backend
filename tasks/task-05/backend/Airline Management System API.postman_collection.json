          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"aircraft_id\": 1,\n    \"members\": [\n        {\"name\": \"Capt. Mohamed Ali\", \"role\": \"Major Pilot\"},\n        {\"name\": \"F.O. Youssef Ibrahim\", \"role\": \"Assistant Pilot\"},\n        {\"name\": \"Sara Ahmed\", \"role\": \"Hostess\"},\n        {\"name\": \"Nour Hassan\", \"role\": \"Hostess\"}\n    ]\n}",
