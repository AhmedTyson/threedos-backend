          "response": []
        },
        {
          "name": "Search Airlines by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/airlines?name=Egypt",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "airlines"
              ],
              "query": [
                {
                  "key": "name",
                  "value": "Egypt",
                  "description": "Search keyword"
                }
              ]
            },
            "description": "Performs a LIKE search on airline names."
          },
          "response": []
        },
        {
          "name": "Create New Airline",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"EgyptAir\",\n    \"address\": \"Cairo International Airport, Cairo, Egypt\",\n    \"contact_person\": \"Ahmed Hassan\",\n    \"phone\": \"+20-2-2696-0000\",\n    \"balance\": 500000\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/airlines",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "airlines"
              ]
            },
            "description": "Creates a new airline. Only `name` is required. Returns the full created record."
          },
          "response": []
        },
        {
          "name": "Update Airline (Partial)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"EgyptAir International\",\n    \"phone\": \"+20-2-2696-1111\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/airlines?id=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "airlines"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            },
            "description": "Partially updates an airline. Only send the fields you want to change."
          },
          "response": []
        },
        {
          "name": "Delete Airline",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/airlines?id=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "airlines"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            },
            "description": "Deletes an airline. Will fail if it has active aircraft, transactions, or routes."
          },
          "response": []
        }
      ]
    },
    {
