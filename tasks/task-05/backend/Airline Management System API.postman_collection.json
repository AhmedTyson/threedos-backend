    {
      "name": "5. Transactions",
      "item": [
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ]
            },
            "description": "Retrieves the full financial ledger with airline names, ordered by date descending."
          },
          "response": []
        },
        {
          "name": "Execute Transaction (Buy)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"airline_id\": 1,\n    \"amount\": 75000,\n    \"type\": \"buy\",\n    \"description\": \"Purchased new engine parts for Boeing 777\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ]
            },
            "description": "Executes a purchase transaction. ACID-compliant: creates the record and subtracts from the airline balance atomically. Fails if balance is insufficient."
          },
          "response": []
        },
        {
          "name": "Execute Transaction (Sell)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"airline_id\": 1,\n    \"amount\": 120000,\n    \"type\": \"sell\",\n    \"description\": \"Revenue from Cairo-Dubai ticket sales\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ]
            },
            "description": "Executes a sale transaction. Adds the amount to the airline balance atomically. Returns the full transaction record."
          },
          "response": []
        },
        {
          "name": "Get Transactions Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions",
                "summary"
              ]
            },
            "description": "Returns an aggregated financial summary: total sales, total purchases, net balance, and transaction count."
          },
          "response": []
        }
      ]
